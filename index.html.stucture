<title>My Personal Profile</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#0d6efd;
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
    padding:20px;
}

.container{
    width:700px;
    background:#fff;
    border-radius:20px;
    padding:30px;
    text-align:center;
    box-shadow:0 10px 25px rgba(0,0,0,0.3);
}

.profile{
    width:180px;
    height:180px;
    border-radius:50%;
    object-fit:cover;
    border:5px solid #0d6efd;
    margin-bottom:20px;
}

h1{
    color:#0d6efd;
    margin-bottom:10px;
}

h2{
    color:#0047ab;
    margin-top:20px;
    margin-bottom:10px;
}

p{
    color:#333;
    line-height:1.6;
    font-size:16px;
}

ul{
    list-style:square;
    text-align:left;
    margin-left:80px;
}

li{
    margin:8px 0;
}

a{
    display:inline-block;
    margin-top:15px;
    padding:10px 20px;
    background:#0d6efd;
    color:white;
    text-decoration:none;
    border-radius:8px;
}

a:hover{
    background:#003d99;
}
</style>

</head>
